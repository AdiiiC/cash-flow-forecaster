# Copy to .env and fill in. With no key, the app uses the deterministic template narrative.

# ---- LLM provider ----------------------------------------------------------
# Which vendor writes the CFO briefing:
#   auto      -> first provider below that has a key (priority: gemini, anthropic, openai)
#   gemini | openai | anthropic -> force that vendor
#   none      -> always use the deterministic template
LLM_PROVIDER=auto

# Set the key(s) for whichever vendor(s) you want to use.
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: pin a specific model. Leave EMPTY to auto-pick the best available
# model for that vendor (falls back gracefully if a newer one is not enabled on
# your account). Preference order used when empty:
#   gemini    -> gemini-2.5-flash, gemini-2.0-flash, gemini-1.5-flash, gemini-1.5-pro
#   openai    -> gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo
#   anthropic -> claude-3-5-sonnet-latest, claude-3-5-haiku-latest, claude-3-haiku-20240307
GEMINI_MODEL=
OPENAI_MODEL=
ANTHROPIC_MODEL=

# The openai / anthropic SDKs are only needed if you use those vendors:
#   pip install openai anthropic

# ---- Server ----------------------------------------------------------------
# CORS origin for the Next.js dev server
FRONTEND_ORIGIN=http://localhost:3000

# ---- Persistence -----------------------------------------------------------
# Run history storage. Leave EMPTY to use a local SQLite file (zero setup,
# but wiped on redeploy on ephemeral hosts). Set to a Postgres URL (Supabase /
# Neon) to make history survive restarts. Use the IPv4 "Session pooler" URL and
# percent-encode any special characters in the password.
#   postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=

# Optional: allow Vercel preview/deploy origins via regex (CORS).
#   FRONTEND_ORIGIN_REGEX=https://cash-flow-forecaster.*\.vercel\.app
FRONTEND_ORIGIN_REGEX=

# ---- Auth ------------------------------------------------------------------
# Secret used to sign JWT access tokens (HS256). MUST be set to a long random
# value in production or all tokens are signed with an insecure dev default.
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
# Access-token lifetime in minutes (default 7 days).
JWT_EXPIRE_MINUTES=10080

# ---- Notifications ---------------------------------------------------------
# Slack Incoming Webhook URL. When set, critical/warning threshold alerts are
# posted to the channel you chose when creating the webhook. Leave EMPTY to
# disable Slack notifications. Create one at https://api.slack.com/apps ->
# Incoming Webhooks. Treat this URL as a secret.
#   SLACK_WEBHOOK_URL=https://hooks.slack.com/services/<TEAM_ID>/<CHANNEL_ID>/<TOKEN>
SLACK_WEBHOOK_URL=

# ---- Data protection -------------------------------------------------------
# Fernet key used to encrypt sensitive text fields at rest (invoice customer /
# bill vendor names). Leave EMPTY in dev to store values as plaintext. In
# production, set a real key. Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DATA_ENCRYPTION_KEY=
