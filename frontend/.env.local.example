# Base URL of the FastAPI backend.
# Use 127.0.0.1 (not localhost) for local dev: the backend listens on IPv4 only,
# and Safari resolves "localhost" to IPv6 (::1) first, causing a startup stall.
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8000

# Server-only secret that unlocks the technical forecaster (/forecast).
# NEVER prefix this with NEXT_PUBLIC_ — that would leak it into the client
# bundle. Only the Edge middleware reads it. Unlock by visiting
# /unlock?key=<this value> or pressing Ctrl+Alt+D and entering it.
# In production, set this in your host's env vars (e.g. Vercel), not in code.
DEV_ACCESS_KEY=choose-a-long-random-secret
